generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  logoUrl      String?
  primaryColor String   @default("#16a34a")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams    Team[]
  products Product[]
  users    User[]
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String
  role           Role     @default(TEAM_MANAGER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])
}

enum Role {
  ADMIN
  TEAM_MANAGER
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  goalAmount  Int      @default(500000)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  users  User[]
  orders Order[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  imageUrl      String?
  category      String   @default("övrigt")
  pricePerUnit  Int      @default(7500)
  profitPerUnit Int      @default(3500)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  orderItems OrderItem[]
}

model Order {
  id              String        @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  note            String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  totalAmount     Int
  totalProfit     Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  items OrderItem[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
}

model OrderItem {
  id         String @id @default(cuid())
  quantity   Int
  unitPrice  Int
  unitProfit Int

  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}
